# .env.example — template biến môi trường cho local dev + CF Pages deploy.
# Copy file này thành `.env` rồi điền giá trị thật (KHÔNG commit .env).

# === nuxt-auth-utils ===
# Seal key cho session cookie. >= 32 ký tự (random cryptographically strong).
# Sinh nhanh: `node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"`
NUXT_SESSION_PASSWORD=

# === Single-user auth (không cần bảng user) ===
# Username hiển thị ở form login.
NUXT_AUTH_USERNAME=

# Scrypt PHC hash cho password. Sinh bằng: `yarn auth:hash <password>` rồi paste vào đây.
# KHÔNG lưu plaintext.
NUXT_AUTH_PASSWORD_HASH=
